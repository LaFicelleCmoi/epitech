# Copier ce fichier en .env.local pour le mode natif (npm run dev)
# ou en .env pour le mode Docker (docker compose up)
# Puis renseigner les valeurs ci-dessous.

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=devuser
DB_PASSWORD=CHANGE_ME
DB_NAME=devdb
POSTGRES_USER=devuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=devdb

# PgAdmin
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME
MONGO_INITDB_DATABASE=chatdb
MONGO_PORT=27017
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=CHANGE_ME
MONGO_EXPRESS_PORT=8081
MONGO_DB=chatdb
MONGO_URI=mongodb://admin:CHANGE_ME@localhost:27017/chatdb?authSource=admin

# JWT — Génère une clé forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# Ports applicatifs
PORT_BACK=3001
PORT_FRONT=3000
